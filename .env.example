# Copie para .env na raiz e preencha antes de rodar `docker compose up`.

# --- Firebase ---
# Id do projeto no console do Firebase
FIREBASE_PROJECT_ID=
# O service account JSON deve existir em apps/api/secrets/firebase-service-account.json

# --- Seed: emails das contas Google, um por unidade ---
SEED_USER_MATRIZ_EMAIL=
SEED_USER_FILIAL_EMAIL=

# --- Opcionais (defaults sensatos no compose) ---
# POSTGRES_USER=minicrm
# POSTGRES_PASSWORD=minicrm
# POSTGRES_DB=minicrm
# Para o frontend hospedado no Firebase, acrescente os domínios do hosting:
# CORS_ORIGINS=http://localhost:5173,https://SEU-PROJETO.web.app,https://SEU-PROJETO.firebaseapp.com

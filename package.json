{
  "name": "mini-crm",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:api": "pnpm --filter api start:dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --filter @mini-crm/shared-types build && pnpm --filter api build && pnpm --filter web build",
    "seed": "pnpm --filter api prisma:seed"
  }
}

# --- Server ---
PORT=3000
# Comma-separated list of allowed browser origins
CORS_ORIGINS=http://localhost:5173

# --- Database (required) ---
DATABASE_URL=postgresql://minicrm:minicrm@localhost:5432/minicrm

# --- Firebase Admin (required from the auth feature onwards) ---
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# --- WhatsApp (Baileys) ---
WA_SESSION_DIR=./sessions

# --- Seed: real Google account e-mails, one per unit ---
SEED_USER_MATRIZ_EMAIL=
SEED_USER_FILIAL_EMAIL=
